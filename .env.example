# Servidor (proxy Bitrix) — não exponha no client
BITRIX_WEBHOOK_URL=https://seudominio.bitrix24.com.br/rest/1/XXXXXXXX/

# Opcional: distribua a carga entre webhooks (recomendado se aparecer "operation time limit")
# Crie 2 webhooks extras no Bitrix (Aplicativos > Webhooks de entrada) com permissão CRM.
BITRIX_WEBHOOK_URL_META=https://seudominio.bitrix24.com.br/rest/1/XXXXXXXX/
BITRIX_WEBHOOK_URL_DEALS=https://seudominio.bitrix24.com.br/rest/2/YYYYYYYY/

# Pausa todas as chamadas ao Bitrix (produção: defina na Vercel e faça um redeploy)
# BITRIX_PAUSED=true

# Cache distribuído opcional — provisionado pelo Upstash no Marketplace da Vercel.
# Sem estas variáveis, o projeto usa somente o cache nativo do Next.js.
UPSTASH_REDIS_REST_URL=https://seu-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=seu_token_upstash
# A integração Vercel também pode injetar os equivalentes KV_REST_API_URL e KV_REST_API_TOKEN.

# Cliente (esteiras)
NEXT_PUBLIC_BITRIX_ESTEIRA_GERAL_ID=16
NEXT_PUBLIC_BITRIX_ESTEIRA_ECONOMICO_ID=64

# SPA de roletas no Bitrix (entity 129). O funil usa categoryId 20 na API REST.
NEXT_PUBLIC_BITRIX_ROLETA_CATEGORY_ID=20

# Supabase Auth — projeto: hejtayrfskmnekcykvjv
NEXT_PUBLIC_SUPABASE_URL=https://hejtayrfskmnekcykvjv.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua_chave_publishable
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_ou_publishable

# Apenas servidor — para criar usuários (npm run seed:admin / gestão de acessos). Nunca expor no client.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_ou_secret_key

# Sincronização Bitrix -> Supabase (somente servidor)
# O CRON_SECRET é enviado automaticamente pela Vercel no Authorization do cron.
CRON_SECRET=gere_um_segredo_longo_e_aleatorio
# Primeira data que ficará disponível nos filtros após o backfill.
BITRIX_SYNC_START_DATE=2026-06-01
# Sobreposição da carga incremental para tolerar atrasos/eventos concorrentes.
BITRIX_SYNC_OVERLAP_MINUTES=60
